# Default property slug loaded on the login page when no URL slug is present.
# Change this to match your primary property's slug in public.properties.slug.
VITE_DEFAULT_SLUG=your-property-slug

# Optional: fix the tenant UUID at build time (single-tenant deployments only).
# Leave unset for multi-tenant / slug-based routing.
# VITE_TENANT_ID=

# POS print / reporting server (Express, port 4000 by default):
# PORT=4000

# Supabase service-role key — ONLY used server-side (Edge Functions, scripts).
# Never set this in the Vite frontend environment.
# SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Cloudflare Workers deployment (used by wrangler deploy):
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
